# Kaggle API Credentials (V1 & V2)
# Get these from your Kaggle Account Settings under the API section.
# Put this file's contents in a new file named '.env' (which is gitignored).

# Option A: For Kaggle API v1 (kaggle.json downloaded from account settings)
KAGGLE_USERNAME="your_kaggle_username"
KAGGLE_KEY="your_kaggle_api_key"

# Option B: For Kaggle API v2 (new tokens starting with KGAT_)
# KAGGLE_API_TOKEN="KGAT_xxxxxxxxxxxxxxxx"
